{
  "name": "Deep Tab",
  "version": "2.0.0",
  "description": "一款用于搜索、应用快捷入口、壁纸和个性化设置的新标签页插件",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "unlimitedStorage",
    "tabs",
    "topSites",
    "bookmarks"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://api.bing.com/*",
    "https://api-hot.imsyy.top/*",
    "https://dailyhot.aizhi.ink/*",
    "https://api.zxki.cn/*",
    "https://dailyhotapi.3yu3.top/*",
    "https://api.open-meteo.com/*",
    "https://*/*",
    "http://*/*",
    "http://localhost:3000/*",
    "http://101.33.234.107:3000/*"
  ],
  "background": {
    "service_worker": "extension/background/index.js"
  },
  "action": {
    "default_title": "Deep Tab",
    "default_icon": "src/assets/images/icon.png",
    "default_popup": "popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "src/assets/images/icon16.png",
    "48": "src/assets/images/icon48.png",
    "128": "src/assets/images/icon128.png"
  }
}
